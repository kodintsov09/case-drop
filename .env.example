# Database
DATABASE_URL="file:./dev.db"

# App URL (must match how you open the site in the browser)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Session signing (min 32 chars). Generate: openssl rand -base64 32
SESSION_SECRET="replace-with-a-long-random-secret-string"

# Steam Web API key — https://steamcommunity.com/dev/apikey
# Лучше хранить в .env.local (не коммитить). Без ключа — вход есть, но ник/аватар generic.
STEAM_API_KEY=""
